# X / Twitter via Apify Tweet Scraper actor (kaitoeasyapi).
# Use a dedicated Apify personal account to isolate billing/risk from Threads.
# https://apify.com/kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest
APIFY_TOKEN_TWITTER=

# Threads via Apify watcher.data/search-threads-by-keywords actor.
# Use a SEPARATE Apify personal account from APIFY_TOKEN_TWITTER (BACKLOG: ToS grey area
# but small-scale individual usage rarely flagged). $8/1000 results pay-per-result.
APIFY_TOKEN_THREADS=

# Threads (Meta API) — kept for the user_handles fetcher (skeleton, disabled).
# Path 4 (Apify scraper above) replaced keyword/topic_tag, so these are optional now.
# If you re-enable user_handles via Meta API, refresh long-lived token every 60 days:
#   GET https://graph.threads.net/refresh_access_token?grant_type=th_refresh_token&access_token=<current>
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=

# Product Hunt API (https://api.producthunt.com)
PRODUCT_HUNT_TOKEN=

# RSSHub instance — rsshub.app is throttled for production use, so we default
# to a community instance. Swap for self-host (spec Appendix D) when needed.
RSSHUB_INSTANCE_URL=https://rsshub.rssforever.com

# wewe-rss (WeChat) — leave empty during PoC; sources.yml has them disabled
WEWE_RSS_URL=
WEWE_RSS_KEY=
