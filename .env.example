# X / Twitter via Apify Tweet Scraper actor (kaitoeasyapi)
# https://apify.com/kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest
# Apify free plan auto-refills $5 platform credits/month → $0 actual cost for ~$1.50/month usage
APIFY_TOKEN=

# Threads (Meta) via official API
# Initial setup at https://developers.facebook.com:
#   create app -> add Threads API product -> add yourself as Threads test user
#   -> enable threads_basic + threads_keyword_search + threads_profile_discovery
#   -> run OAuth dialog flow (NOT Token Generator — that only emits threads_basic)
#   -> exchange code for short-lived then long-lived token (see Appendix B in spec)
# Long-lived token is valid 60 days. Refresh it via:
#   GET https://graph.threads.net/refresh_access_token?grant_type=th_refresh_token&access_token=<current>
# Then update GitHub Secret THREADS_ACCESS_TOKEN.
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=

# Product Hunt API (https://api.producthunt.com)
PRODUCT_HUNT_TOKEN=

# RSSHub instance — rsshub.app is throttled for production use, so we default
# to a community instance. Swap for self-host (spec Appendix D) when needed.
RSSHUB_INSTANCE_URL=https://rsshub.rssforever.com

# wewe-rss (WeChat) — leave empty during PoC; sources.yml has them disabled
WEWE_RSS_URL=
WEWE_RSS_KEY=
